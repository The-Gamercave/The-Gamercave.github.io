    "sections": [
        {
            "name": "Prematch",
            "fields": [
                {
                    "title": "Scouter Name",
                    "description": "Enter the name of the scouter.",
                    "type": "text",
                    "required": true,
                    "code": "scouter",
                    "formResetBehavior": "preserve",
                    "defaultValue": ""
                },
                {
                    "title": "Team Number",
                    "description": "Enter the team number.",
                    "type": "number",
                    "required": true,
                    "code": "teamNumber",
                    "formResetBehavior": "preserve",
                    "defaultValue": 0
                },
                {
                    "title": "Match Number",
                    "description": "Enter the match number.",
                    "type": "number",
                    "required": true,
                    "code": "matchNumber",
                    "formResetBehavior": "increment",
                    "defaultValue": 1
                },
                {
                    "title": "Team Color",
                    "description": "Select the team color.",
                    "type": "select",
                    "required": true,
                    "code": "teamColor",
                    "formResetBehavior": "preserve",
                    "defaultValue": "Red",
                    "choices": {
                        "Red": "Red",
                        "Blue": "Blue"
                    }
                }
            ]
        },
        {
            "name": "Autonomous",
            "fields": [
                {
                    "title": "Number of trips",
                    "description": "How many trips were made in autonomous?",
                    "type": "counter",
                    "required": false,
                    "code": "autoTrips",
                    "formResetBehavior": "reset",
                    "defaultValue": 0,
                    "min": 0,
                    "step": 1
                },
                {
                    "title": "Climb Y/N",
                    "description": "Did the robot climb during autonomous?",
                    "type": "boolean",
                    "required": false,
                    "code": "autoClimb",
                    "formResetBehavior": "reset",
                    "defaultValue": false
                },
                {
                    "title": "Not active? Y/N",
                    "description": "Was the robot not active during auto?",
                    "type": "boolean",
                    "required": false,
                    "code": "autoNotActive",
                    "formResetBehavior": "reset",
                    "defaultValue": false
                }
            ]
        },
        {
            "name": "Teleop",
            "fields": [
                {
                    "title": "Number of trips",
                    "description": "How many trips were made in teleop?",
                    "type": "counter",
                    "required": false,
                    "code": "teleopTrips",
                    "formResetBehavior": "reset",
                    "defaultValue": 0,
                    "min": 0,
                    "step": 1
                },
                {
                    "title": "Approx Load",
                    "description": "Approximate load level.",
                    "type": "select",
                    "required": false,
                    "code": "approxLoad",
                    "formResetBehavior": "reset",
                    "defaultValue": "Low",
                    "choices": {
                        "None": "None",
                        "Low": "Low",
                        "Medium": "Medium",
                        "High": "High",
                        "Full": "Full"
                    }
                },
                {
                    "title": "Shooting Positions Map",
                    "description": "Tap the map to add shooting positions.",
                    "type": "map",
                    "required": false,
                    "code": "shootingPositions",
                    "formResetBehavior": "reset",
                    "defaultValue": [],
                    "imageSrc": "https://dummyimage.com/600x340/e2e8f0/64748b.png&text=2026+Field+Map+Placeholder"
                },
                {
                    "title": "Not active? Y/N",
                    "description": "Was the robot not active during teleop?",
                    "type": "boolean",
                    "required": false,
                    "code": "teleopNotActive",
                    "formResetBehavior": "reset",
                    "defaultValue": false
                }
            ]
        },
        {
            "name": "Endgame",
            "fields": [
                {
                    "title": "Climb Y/N",
                    "description": "Did the robot climb?",
                    "type": "boolean",
                    "required": false,
                    "code": "endgameClimb",
                    "formResetBehavior": "reset",
                    "defaultValue": false
                },
                {
                    "title": "Climb Lvl 1 2 3",
                    "description": "Which level did they climb to?",
                    "type": "select",
                    "required": false,
                    "code": "endgameClimbLevel",
                    "formResetBehavior": "reset",
                    "defaultValue": "None",
                    "choices": {
                        "None": "None",
                        "L1": "Level 1",
                        "L2": "Level 2",
                        "L3": "Level 3"
                    }
                },
                {
                    "title": "Shoots from multiple angles? Y/N",
                    "description": "Can the robot shoot from multiple angles?",
                    "type": "boolean",
                    "required": false,
                    "code": "multipleAngles",
                    "formResetBehavior": "reset",
                    "defaultValue": false
                },
                {
                    "title": "Under or over",
                    "description": "Does the robot shoot under, over, both, or neither?",
                    "type": "select",
                    "required": false,
                    "code": "underOrOver",
                    "formResetBehavior": "reset",
                    "defaultValue": "Neither",
                    "choices": {
                        "Neither": "Neither",
                        "Under": "Under",
                        "Over": "Over",
                        "Both": "Both"
                    }
                },
                {
                    "title": "Defend? Y/N",
                    "description": "Did the robot play defense?",
                    "type": "boolean",
                    "required": false,
                    "code": "defend",
                    "formResetBehavior": "reset",
                    "defaultValue": false
                },
                {
                    "title": "Flying carpet? Y/N",
                    "description": "Did the robot use a flying carpet?",
                    "type": "boolean",
                    "required": false,
                    "code": "flyingCarpet",
                    "formResetBehavior": "reset",
                    "defaultValue": false
                },
                {
                    "title": "Accuracy 1-5",
                    "description": "Rate the robot's accuracy from 1 to 5.",
                    "type": "range",
                    "required": false,
                    "code": "accuracy",
                    "formResetBehavior": "reset",
                    "defaultValue": 3,
                    "min": 1,
                    "max": 5,
                    "step": 1
                }
            ]
        }
    ]
